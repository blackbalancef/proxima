# Telegram Bot
TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# Anthropic
ANTHROPIC_API_KEY=your-anthropic-api-key

# Access control (comma-separated Telegram user IDs)
ALLOWED_USER_IDS=123456789

# Working directory for Claude Code (default: current directory)
# WORK_DIR=/path/to/projects

# OpenAI (for Whisper voice transcription, optional)
# OPENAI_API_KEY=your-openai-api-key

# PostgreSQL
DATABASE_URL=postgresql://proxima:dev@localhost:5432/proxima

# Log level (debug, info, warn, error)
LOG_LEVEL=info
