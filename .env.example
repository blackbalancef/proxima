# Telegram Bot
TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# Access control (comma-separated Telegram user IDs)
ALLOWED_USER_IDS=123456789

# Working directory for Claude Code (default: ./projects/)
# Set absolute path to allow Claude Code to work anywhere on the server
# WORK_DIR=/path/to/projects

# Anthropic API key (optional; Claude Code CLI auth can also be used)
# ANTHROPIC_API_KEY=your-anthropic-api-key

# OpenAI (for Whisper voice transcription, optional)
# OPENAI_API_KEY=your-openai-api-key

# Whisper transcription language (ISO-639-1 code, optional)
# If not set, Whisper auto-detects the language.
# Examples: en, ru, de, fr, es, zh, ja, ko
# WHISPER_LANGUAGE=ru

# PostgreSQL
DATABASE_URL=postgresql://proxima:dev@localhost:5432/proxima

# Log level (debug, info, warn, error)
LOG_LEVEL=info

# Session timeout (minutes, default: 30)
# SESSION_TIMEOUT=30
